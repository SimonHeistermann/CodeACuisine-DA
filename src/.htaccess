# ============================================================
# Code à Cuisine – Apache Configuration
# Angular SPA on ALL-INKL / Apache shared hosting
# ============================================================

RewriteEngine On

# --- HTTPS redirect ---
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Angular SPA routing ---
# Serve existing files/directories directly, route everything else to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# --- Security headers ---
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Clickjacking protection
  Header set X-Frame-Options "DENY"

  # XSS filter (legacy browsers)
  Header set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions policy (no camera, microphone, geolocation needed)
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- Caching ---
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed JS/CSS bundles – long cache (Angular uses content hashes in filenames)
  <FilesMatch "\.(js|css)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Fonts – long cache
  <FilesMatch "\.(woff2|woff|ttf|eot)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images – moderate cache
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|webp)$">
    ExpiresDefault "access plus 1 month"
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML – no cache (Angular updates index.html on deploy)
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # JSON – short cache
  <FilesMatch "\.json$">
    ExpiresDefault "access plus 1 hour"
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# --- Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/font-woff2
</IfModule>

# --- Prevent access to dotfiles ---
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
